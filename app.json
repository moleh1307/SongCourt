{
  "expo": {
    "name": "SongCourt",
    "slug": "songcourt",
    "scheme": "songcourt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/premium/app-icon-seal.png",
      "resizeMode": "contain",
      "backgroundColor": "#06070B"
    },
    "ios": {
      "bundleIdentifier": "com.melihkarakose.songcourt",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "SongCourt saves verdict cards to your photo library when you choose Save Image."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06070B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
