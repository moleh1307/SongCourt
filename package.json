{
  "name": "songcourt",
  "version": "1.0.0",
  "description": "SongCourt iPhone app and backend API for Spotify OAuth and music snapshot normalization.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && find api -type f -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-view-shot": "4.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
